# Flownt Bridge – Konfiguration
# 1. Kopiere diese Datei zu ".env" (cp .env.example .env)
# 2. Fülle alle Werte aus (Auth-Token aus dem Drucker-Modal in Flownt kopieren)

# Auth-Token aus Flownt (Drucker → Bearbeiten → Bridge-Verbindung → Token)
FLOWNT_AUTH_TOKEN=

# Supabase Edge Function URL (ohne trailing slash)
# Format: https://<project-ref>.supabase.co/functions/v1
FLOWNT_EDGE_URL=https://DEINE-PROJEKT-REF.supabase.co/functions/v1

# Adapter (aktuell nur moonraker unterstützt)
ADAPTER_TYPE=moonraker

# Lokale URL deines Moonraker/Klipper-Druckers (kein trailing slash)
ADAPTER_URL=http://192.168.1.100

# Moonraker API-Key (optional, nur wenn in moonraker.conf konfiguriert)
ADAPTER_API_KEY=

# Polling-Intervall in Sekunden (Standard: 30)
POLLING_INTERVAL_S=30
