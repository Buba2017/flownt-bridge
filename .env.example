# Flownt Bridge – Konfiguration
# 1. Kopiere diese Datei zu ".env":  cp .env.example .env
# 2. Fülle alle Pflichtfelder aus

# ── Flownt ────────────────────────────────────────────────────────────────────

# Auth-Token aus Flownt (Drucker → Bearbeiten → Bridge-Verbindung → Token)
FLOWNT_AUTH_TOKEN=

# Supabase Edge Function URL — Format: https://<project-ref>.supabase.co/functions/v1
FLOWNT_EDGE_URL=https://DEINE-PROJEKT-REF.supabase.co/functions/v1

# ── Adapter ───────────────────────────────────────────────────────────────────
# Wähle deinen Drucker-Typ: moonraker | bambu

ADAPTER_TYPE=bambu

# ── Bambu Lab (ADAPTER_TYPE=bambu) ────────────────────────────────────────────
# Alle drei Werte findest du am Drucker-Display unter Einstellungen → Netzwerk

# IP-Adresse des Druckers im lokalen Netzwerk (ohne http://)
ADAPTER_URL=192.168.1.100

# Seriennummer (z.B. 00M09A123456789)
ADAPTER_SERIAL=

# Access Code (8-stelliger Code am Display)
ADAPTER_API_KEY=

# ── Moonraker / Klipper (ADAPTER_TYPE=moonraker) ──────────────────────────────
# ADAPTER_URL=http://192.168.1.100        # mit http://
# ADAPTER_API_KEY=                        # optional, nur wenn in moonraker.conf gesetzt
# ADAPTER_SERIAL=                         # nicht benötigt

# ── Allgemein ─────────────────────────────────────────────────────────────────

# Wie oft Flownt aktualisiert wird (Sekunden). Bambu: 30s reicht, da MQTT push-basiert ist
POLLING_INTERVAL_S=30
